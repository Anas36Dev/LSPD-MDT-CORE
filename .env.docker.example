# =============================================================================
# Exemple de configuration pour un déploiement Docker.
# Copiez ce fichier en « .env » (à côté de docker-compose.yml) et ajustez.
# docker compose lit ce .env pour la substitution ${...} ET l'injecte dans l'app.
# =============================================================================

# --- Base de données (service `db` du compose) ------------------------------
# Mot de passe root MariaDB et nom de la base. NE PAS mettre DATABASE_URL ici :
# le compose la construit automatiquement vers le service `db`.
DB_PASSWORD=change_moi_en_prod
DB_NAME=lspd_mdt

# --- Application ------------------------------------------------------------
# Port exposé sur la machine hôte (http://localhost:APP_PORT).
APP_PORT=3000
# URL publique du site (utilisée pour les redirections et Discord OAuth).
APP_URL=http://localhost:3000
# Rejoue le seed idempotent à chaque démarrage (mettre false une fois installé).
SEED_ON_START=true

# --- Connexion Discord (optionnelle) ----------------------------------------
# Laisser vide désactive proprement le bouton « Se connecter avec Discord ».
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=
DISCORD_BOT_TOKEN=
